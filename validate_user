def validate_user(user_data:dict)->bool:
    name = user_data.get("name")
    email=user_data.get("email")
    age = user_data.get("age")
    if not name:
        return False
    if not email and "@" in email and "." in email:
        return False
    if not age and 18<=age<=100:
        return False
    return True

user_data={
    "name": "Bob",
